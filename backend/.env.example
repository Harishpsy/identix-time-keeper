# Backend Environment Variables Template
# Copy this file to .env and fill in your actual credentials

PORT=5000
NODE_ENV=development

# Database Configuration (Development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password_here
DB_NAME=identix

# Database Configuration (Production)
PROD_DB_HOST=localhost
PROD_DB_PORT=3306
PROD_DB_USER=root
PROD_DB_PASS=your_password_here
PROD_DB_NAME=identix_prod

# Security
JWT_SECRET=your_long_random_string_here
ENCRYPTION_KEY=32_character_string_for_crypto
ENCRYPTION_ENABLED=true

# Initial Admin Credentials (used only by seed-admin.js)
INITIAL_ADMIN_EMAIL=admin@identixhr.com
INITIAL_ADMIN_PASSWORD=Admin@123
